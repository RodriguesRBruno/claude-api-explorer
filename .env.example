# QuizAPI credentials (required)
QUIZ_API_KEY=your_quizapi_key_here

# Claude API authentication (choose one of the two below)
# Option 1: OAuth token (preferred if running via Claude Code)
CLAUDE_CODE_OAUTH_TOKEN=your_claude_code_token_here

# Option 2: Open Router API Key (any of Options 1, 2 or 3 works)
# OPEN_ROUTER_API_KEY=your_open_router_api_key_here
# Option 3: API key (any of Options 1, 2 or 3 works)
# ANTHROPIC_API_KEY=your_anthropic_api_key_here